# =============================================================================
# AXIOM Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# Supabase — get from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — used SERVER-SIDE only (API routes / agents)
# NEVER expose this to the browser. Keep it out of NEXT_PUBLIC_ vars.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# PowerSync — get from https://app.powersync.com after connecting Supabase
NEXT_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# Mastra / AI Agent models (via OpenRouter)
OPENROUTER_API_KEY=your-openrouter-api-key-here
